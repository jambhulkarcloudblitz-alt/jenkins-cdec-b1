pipeline {
    agent any
    stages {
        stage ('PULL'){
            steps {
                echo 'PULL SUCCSESS'
            }
        }
        stage ('BUILD'){
            steps {
                echo 'BUILD SUCCESS'
            }
        }
        stage ('TEST'){
            steps {
                echo 'TEST SUCCESS'   
            }
        }
        stage ('DEPLOY'){
            steps {
                echo 'DEPLOY SUCCESS'
            }
        }
        
    }
}